# 复制为 .env 并按需修改
APP_NAME=数据质量监测平台
DATA_DIR=data
UPLOAD_DIR=data/uploads
GENERATED_DIR=data/generated
RULESET_DIR=data/rulesets
DATABASE_URL=sqlite:///data/quality.db
SAMPLE_LIMIT=50

# ----- MySQL 数据源（可选） -----
# 每组连接用 MYSQL_<NAME>_{HOST,PORT,USER,PASSWORD,DATABASE} 配置
# 至少配置一组（名为 DEFAULT）才能在 /upload 页看到 MySQL 表单
# MYSQL_DEFAULT_HOST=127.0.0.1
# MYSQL_DEFAULT_PORT=3306
# MYSQL_DEFAULT_USER=root
# MYSQL_DEFAULT_PASSWORD=your_password
# MYSQL_DEFAULT_DATABASE=mydb

# 多个连接示例：
# MYSQL_BI_HOST=bi.example.com
# MYSQL_BI_USER=reader
# MYSQL_BI_PASSWORD=secret
# MYSQL_BI_DATABASE=bi

# 安全：限制仅允许白名单中的连接（不配置则无限制，但生产建议设）
# MYSQL_ALLOWED_CONNECTIONS=DEFAULT,BI

# ----- UI 配置连接所需的加密密钥 -----
# 用于加密存到 data/mysql_connections.yaml 里的密码
# 首次运行会自动生成（在 data/.secret_key），生产环境请显式设置
# SECRET_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
